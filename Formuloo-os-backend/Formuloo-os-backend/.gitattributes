# Force LF line endings in the repo for all text files
* text=auto eol=lf

# Python files always LF
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.sh text eol=lf

# Windows-specific — keep CRLF only for bat/cmd
*.bat text eol=crlf
*.cmd text eol=crlf
