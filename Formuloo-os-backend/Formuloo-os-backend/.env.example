# ============================================================
# .env.example — Formuloo OS
# Copier vers .env et adapter les valeurs
# NE JAMAIS COMMITER .env en production
# ============================================================

# ── Commun ───────────────────────────────────────────────────
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.99.100

# ── Base de données (partagé Auth + HR) ──────────────────────
DB_USER=formuloo
DB_PASSWORD=changeme

# ── Auth ─────────────────────────────────────────────────────
AUTH_SECRET_KEY=django-insecure-change-this-in-production-auth
AUTH_DB_NAME=formuloo_auth
ACCESS_TOKEN_LIFETIME=15
REFRESH_TOKEN_LIFETIME=7
FRONTEND_URL=http://localhost:3000
# En prod : domaine du frontend (ex: https://app.formuloo.cm)
# Liste séparée par virgule si plusieurs domaines
CORS_ALLOWED_ORIGINS=https://app.formuloo.cm

# ── HR ───────────────────────────────────────────────────────
HR_SECRET_KEY=django-insecure-change-this-in-production-hr
HR_DB_NAME=formuloo_hr
# AUTH_SECRET_KEY est partagé avec HR pour valider les JWT

# ── COMPTA ───────────────────────────────────────────────────
COMPTA_SECRET_KEY=django-insecure-change-this-in-production-compta
COMPTA_DB_NAME=formuloo_compta

# ── GESDOC (Gestion Documentaire OCR + Blockchain) ────────────
GESDOC_SECRET_KEY=django-insecure-change-this-in-production-gesdoc
GESDOC_DB_NAME=formuloo_gesdoc
# Ancrage blockchain — Ethereum Sepolia via Infura (https://infura.io)
# et wallet Sepolia financé en ETH de test (https://sepoliafaucet.com).
# CONTRACT_ADDRESS est renseigné après déploiement de DocumentRegistry.sol
# (services/gesdoc/blockchain/) via `truffle migrate --network sepolia`.
BLOCKCHAIN_NETWORK=sepolia
INFURA_PROJECT_ID=
SEPOLIA_PRIVATE_KEY=
CONTRACT_ADDRESS=

# ── COMMUNICATION INTER-SERVICES ──────────────────────────────
# Partagé entre Auth, HR et Compta — réseau Docker interne uniquement
# Changer absolument en production
INTERNAL_SERVICE_TOKEN=formuloo-internal-secret-change-in-prod

# ── Email (commun à HR et Compta) ─────────────────────────────
# En dev, utiliser console pour éviter l'envoi réel :
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre.adresse@gmail.com
EMAIL_HOST_PASSWORD=mot_de_passe_application
DEFAULT_FROM_EMAIL=Formuloo OS <noreply@formuloo.cm>
