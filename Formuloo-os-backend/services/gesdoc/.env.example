# ============================================================
# .env.example — Service GesDoc — Formuloo OS
# Copier vers .env et adapter les valeurs
# NE JAMAIS COMMITER .env en production
# ============================================================

SECRET_KEY=django-insecure-change-this-in-production-gesdoc
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.99.100

DB_NAME=formuloo_gesdoc
DB_USER=formuloo
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5437

REDIS_URL=redis://localhost:6379/3
CELERY_BROKER_URL=redis://localhost:6379/4
CELERY_RESULT_BACKEND=redis://localhost:6379/4
CELERY_TASK_ALWAYS_EAGER=0

# Partage avec Auth pour valider les JWT emis par le service Auth
AUTH_SECRET_KEY=django-insecure-change-this-in-production-auth
ACCESS_TOKEN_LIFETIME=15
REFRESH_TOKEN_LIFETIME=7

# Communication inter-services (partage avec Auth/HR/Compta)
INTERNAL_SERVICE_TOKEN=formuloo-internal-secret-change-in-prod
COMPTA_SERVICE_URL=http://localhost:8002

FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=https://app.formuloo.cm

# ── Stockage local (volume Docker) ────────────────────────────
MEDIA_ROOT=./media
DOCUMENT_MAX_UPLOAD_SIZE=20971520
SIGNED_URL_EXPIRY_SECONDS=900

# ── Pipeline OCR ───────────────────────────────────────────────
OCR_FALLBACK_CONFIDENCE_THRESHOLD=80
TESSERACT_CMD=tesseract
TESSERACT_LANG=fra
CAMEMBERT_QA_MODEL=illuin/camembert-base-fquad
SPACY_MODEL=fr_core_news_lg

# ── Blockchain — Ethereum Sepolia via Infura ──────────────────
# A fournir : projet Infura (https://infura.io) + wallet Sepolia
# finance en ETH de test (https://sepoliafaucet.com)
BLOCKCHAIN_NETWORK=sepolia
INFURA_PROJECT_ID=
SEPOLIA_PRIVATE_KEY=
CONTRACT_ADDRESS=
ETHERSCAN_BASE_URL=https://sepolia.etherscan.io
